def cmd_pack(args):
    """Generate a token-budget-aware evidence bundle for LLM handoff.

    Searches the same way as `search` and formats results as a numbered list
    with resume commands — ready to paste into an LLM context window.
    Use --tokens to truncate each prompt to approximately N tokens (4 chars/token).
    """
    conn = sqlite3.connect(str(DB_PATH))
    init_db(conn)
    query = _build_fts_query(args.query, getattr(args, "fts", False))

    sql = (
        "SELECT h.id, h.source, h.session_id, h.project, h.prompt, h.timestamp_ms "
        "FROM history_fts f JOIN history h ON f.rowid = h.id "
        "WHERE history_fts MATCH ? "
    )
    params = [query]
    if args.source:
        sql += "AND h.source = ? "
        params.append(args.source)
    if args.project:
        sql += "AND h.project LIKE ? "
        params.append(f"%{args.project}%")
    if getattr(args, "tag", None):
        sql += f"AND {_tag_filter_clause('h')} "
        params.append(_normalize_tag_name(args.tag))
    sql += "ORDER BY h.timestamp_ms DESC LIMIT ?"
    params.append(args.limit)

    rows = conn.execute(sql, params).fetchall()
    conn.close()

    if not rows:
        if getattr(args, "json", False):
            print(json.dumps({"query": " ".join(args.query), "entries": []}))
        else:
            print("No results.")
        sys.exit(1)

    chars_budget = args.tokens * 4 if args.tokens else None
    query_str = " ".join(args.query)
    now_ms = int(time.time() * 1000)

    if getattr(args, "json", False):
        entries = []
        for r in rows:
            id_, source, session_id, project, prompt, ts_ms = r
            text = prompt[:chars_budget] if chars_budget and len(prompt) > chars_budget else prompt
            entries.append({
                "id": id_,
                "source": source,
                "session_id": session_id,
                "project": project,
                "prompt": text,
                "timestamp_ms": ts_ms,
                "resume_cmd": _resume_cmd(source, session_id, project),
            })
        print(json.dumps({
            "query": query_str,
            "generated_ms": now_ms,
            "token_budget": args.tokens,
            "entries": entries,
        }))
        return

    dt = time.strftime("%Y-%m-%d %H:%M", time.localtime(now_ms / 1000))
    print(f'=== ai-hist pack: "{query_str}" | {dt} | {len(rows)} entries ===\n')
    for i, r in enumerate(rows, 1):
        id_, source, session_id, project, prompt, ts_ms = r
        entry_dt = time.strftime("%Y-%m-%d %H:%M", time.localtime(ts_ms / 1000))
        proj = f"  {project}" if project else ""
        if chars_budget and len(prompt) > chars_budget:
            text = prompt[:chars_budget].replace("\n", " ") + "..."
        else:
            text = prompt.replace("\n", " ")
        print(f"[{i}/{len(rows)}] #{id_}  {entry_dt}  {source}{proj}")
        print(f"      {text}")
        if session_id:
            cmd = _resume_cmd(source, session_id, project)
            sid_short = session_id[:16] + "..." if len(session_id) > 16 else session_id
            if cmd:
                print(f"      Resume: {cmd}")
            else:
                print(f"      Session: {sid_short}")
        print()


