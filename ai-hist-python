GIT_HOOK_MARKER_BEGIN = "# ai-hist session commit link (managed begin)"
GIT_HOOK_MARKER_END = "# ai-hist session commit link (managed end)"
AI_HIST_NOTE_REF = "ai-hist"


def _git(repo, *args):
    proc = subprocess.run(
        ["git", *args],
        cwd=str(repo),
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )
    if proc.returncode != 0:
        raise RuntimeError(f"git {' '.join(args)} failed: {proc.stderr.strip()}")
    return proc.stdout.strip()


def _git_root(repo):
    return Path(_git(repo, "rev-parse", "--show-toplevel"))


def _git_branch(repo):
    branch = _git(repo, "rev-parse", "--abbrev-ref", "HEAD")
    return None if branch == "HEAD" else branch


def _git_commit_files(repo, commit):
    out = _git(repo, "diff-tree", "--root", "--no-commit-id", "--name-only", "-r", commit)
    return [line.strip() for line in out.splitlines() if line.strip()]


def _git_commit_numstat(repo, commit):
    out = _git(repo, "diff-tree", "--root", "--numstat", "--no-commit-id", "-r", commit)
    rows = []
    for line in out.splitlines():
        parts = line.split("\t")
        if len(parts) >= 3:
            rows.append({
                "path": parts[2],
                "additions": int(parts[0]) if parts[0].isdigit() else None,
                "deletions": int(parts[1]) if parts[1].isdigit() else None,
            })
    return rows


def _session_file_overlap(conn, source, session_id, files):
    if not files:
        return 0
    rows = conn.execute(
        "SELECT DISTINCT file_path FROM file_edits WHERE source = ? AND session_id = ?",
        (source, session_id),
    ).fetchall()
    session_files = [r[0] for r in rows]
    return sum(
        1 for f in files
        if any(sf == f or sf.endswith(f) or f.endswith(sf) for sf in session_files)
    )


def _find_session_for_commit(conn, repo_root, branch, commit_ms, files):
    repo = str(repo_root)
    try:
        repo_canonical = repo_root.resolve()
    except OSError:
        repo_canonical = repo_root
    min_ms = commit_ms - 36 * 60 * 60 * 1000
    max_ms = commit_ms + 6 * 60 * 60 * 1000
    rows = conn.execute(
        "SELECT source, session_id, cwd, git_branch, first_activity_ms, last_activity_ms "
        "FROM sessions WHERE session_id IS NOT NULL "
        "AND COALESCE(last_activity_ms, first_activity_ms, 0) BETWEEN ? AND ?",
        (min_ms, max_ms),
    ).fetchall()
    best = None
    for source, session_id, cwd, git_branch, first_ms, last_ms in rows:
        cwd_match = bool(cwd and _cwd_matches_repo(cwd, repo, repo_canonical))
        branch_match = bool(branch and git_branch and branch == git_branch)
        if not cwd_match and not branch_match:
            continue
        last = last_ms or first_ms or commit_ms
        first = first_ms or last
        if commit_ms < first:
            distance = first - commit_ms
        elif commit_ms > last:
            distance = commit_ms - last
        else:
            distance = 0
        overlap = _session_file_overlap(conn, source, session_id, files)
        confidence = 0.45
        if cwd_match:
            confidence += 0.20
        if branch_match:
            confidence += 0.20
        if distance == 0:
            confidence += 0.10
        elif distance <= 2 * 60 * 60 * 1000:
            confidence += 0.05
        if overlap:
            confidence += 0.05
        confidence = min(confidence, 0.98)
        evidence = {
            "cwd": cwd,
            "git_branch": git_branch,
            "first_activity_ms": first_ms,
            "last_activity_ms": last_ms,
            "cwd_match": cwd_match,
            "branch_match": branch_match,
            "time_distance_ms": distance,
            "file_overlap": overlap,
        }
        candidate = (confidence, source, session_id, evidence)
        if best is None or confidence > best[0]:
            best = candidate
    return best


def _cwd_matches_repo(cwd, repo, repo_canonical):
    if cwd == repo or cwd.startswith(repo + "/"):
        return True
    try:
        cwd_canonical = Path(cwd).resolve()
        return cwd_canonical == repo_canonical or repo_canonical in cwd_canonical.parents
    except OSError:
        return False


def cmd_setup_git(args):
    root = _git_root(Path(args.repo))
    hook_path = root / ".git" / "hooks" / "post-commit"
    if args.uninstall:
        if not hook_path.exists():
            print("No ai-hist post-commit hook installed.")
            return
        text = hook_path.read_text()
        if GIT_HOOK_MARKER_BEGIN not in text:
            print(f"{hook_path} is not managed by ai-hist; refusing to remove it.", file=sys.stderr)
            sys.exit(1)
        hook_path.unlink()
        print(f"Removed ai-hist post-commit hook: {hook_path}")
        return
    existing = hook_path.read_text() if hook_path.exists() else ""
    if existing.strip() and GIT_HOOK_MARKER_BEGIN not in existing:
        print(f"{hook_path} already exists and is not managed by ai-hist.", file=sys.stderr)
        sys.exit(1)
    hook_path.parent.mkdir(parents=True, exist_ok=True)
    script = (
        "#!/bin/sh\n"
        f"{GIT_HOOK_MARKER_BEGIN}\n"
        f"AI_HIST_DB={_shell_quote(str(DB_PATH))} {_shell_quote(sys.argv[0])} "
        f"link commit --repo {_shell_quote(str(root))} --commit HEAD "
        "--match-method git_note --quiet >/dev/null 2>>/tmp/ai-hist-git-link.err || true\n"
        f"{GIT_HOOK_MARKER_END}\n"
    )
    hook_path.write_text(script)
    hook_path.chmod(hook_path.stat().st_mode | 0o755)
    print("Installed ai-hist post-commit hook.")
    print(f"  repo: {root}")
    print(f"  hook: {hook_path}")
    print(f"  notes: refs/notes/{AI_HIST_NOTE_REF}")


def cmd_link_commit(args):
    conn = sqlite3.connect(str(DB_PATH))
    init_db(conn)
    root = _git_root(Path(args.repo))
    commit_sha = _git(root, "rev-parse", args.commit)
    commit_ms = int(_git(root, "show", "-s", "--format=%ct", commit_sha)) * 1000
    try:
        branch = _git_branch(root)
    except Exception:
        branch = None
    try:
        remote = _strip_url_credentials(_git(root, "remote", "get-url", "origin"))
    except Exception:
        remote = None
    files = _git_commit_files(root, commit_sha)
    numstat = _git_commit_numstat(root, commit_sha)
    candidate = _find_session_for_commit(conn, root, branch, commit_ms, files)
    if candidate is None:
        if args.json:
            print(json.dumps({"linked": False, "repo": str(root), "commit_sha": commit_sha, "reason": "no matching session"}))
        elif not args.quiet:
            print(f"No matching session found for {commit_sha} in {root}")
        conn.close()
        return
    confidence, source, session_id, candidate_evidence = candidate
    created_at_ms = int(time.time() * 1000)
    note_ref = f"refs/notes/{AI_HIST_NOTE_REF}" if not args.no_note else None
    evidence = {
        "repo_path": str(root),
        "repo_remote": remote,
        "branch": branch,
        "commit_time_ms": commit_ms,
        "candidate": candidate_evidence,
        "files": files,
        "numstat": numstat,
    }
    if not args.no_note:
        note = {
            "schema": "ai-hist.session_commit_link.v1",
            "source": source,
            "session_id": session_id,
            "repo": str(root),
            "branch": branch,
            "commit_sha": commit_sha,
            "match_method": args.match_method,
            "confidence": confidence,
            "created_at_ms": created_at_ms,
        }
        subprocess.run(
            ["git", "notes", f"--ref={AI_HIST_NOTE_REF}", "add", "-f", "-m", json.dumps(note), commit_sha],
            cwd=str(root),
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
    conn.execute(
        "INSERT INTO session_commit_links "
        "(source, session_id, repo, branch, commit_sha, note_ref, match_method, confidence, files_json, numstat_json, evidence_json, created_at_ms) "
        "VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?) "
        "ON CONFLICT(source, session_id, commit_sha, match_method) DO UPDATE SET "
        "repo=excluded.repo, branch=excluded.branch, note_ref=excluded.note_ref, confidence=excluded.confidence, "
        "files_json=excluded.files_json, numstat_json=excluded.numstat_json, evidence_json=excluded.evidence_json, created_at_ms=excluded.created_at_ms",
        (source, session_id, str(root), branch, commit_sha, note_ref, args.match_method, confidence,
         json.dumps(files), json.dumps(numstat), json.dumps(evidence), created_at_ms),
    )
    conn.commit()
    conn.close()
    out = {
        "linked": True,
        "source": source,
        "session_id": session_id,
        "repo": str(root),
        "branch": branch,
        "commit_sha": commit_sha,
        "note_ref": note_ref,
        "match_method": args.match_method,
        "confidence": confidence,
        "files": files,
        "numstat": numstat,
        "evidence": evidence,
        "created_at_ms": created_at_ms,
    }
    if args.json:
        print(json.dumps(out))
    elif not args.quiet:
        print(f"Linked {source}:{session_id} → {commit_sha} ({args.match_method}, confidence {confidence:.2f})")


# --- Export / Import ---------------------------------------------------------

_EXPORT_FIELDS = ["source", "session_id", "project", "prompt", "prompt_hash", "timestamp_ms"]


def _parse_date_to_ms(date_str):
    try:
        t = time.strptime(date_str, "%Y-%m-%d")
        return int(time.mktime(t)) * 1000
    except ValueError:
        print(f"Invalid date '{date_str}'. Use YYYY-MM-DD.", file=sys.stderr)
        sys.exit(1)


def _open_file(path, mode="rt"):
    """Open a file, transparently handling .gz compression."""
    if path.endswith(".gz"):
        return gzip.open(path, mode, encoding="utf-8")
    return open(path, mode, encoding="utf-8")


def _query_export_rows(conn, args):
    sql = (
        "SELECT source, session_id, project, prompt, prompt_hash, timestamp_ms "
        "FROM history WHERE 1=1"
    )
    params = []
    if getattr(args, "source", None):
        sql += " AND source = ?"
        params.append(args.source)
    if getattr(args, "project", None):
        sql += " AND project LIKE ?"
        params.append(f"%{args.project}%")
    if getattr(args, "since", None):
        sql += " AND timestamp_ms >= ?"
        params.append(_parse_date_to_ms(args.since))
    sql += " ORDER BY timestamp_ms ASC"
    return conn.execute(sql, params).fetchall()


def cmd_export(args):
    """Export history to a portable JSONL or SQLite file.

    JSONL is the default — one JSON object per line, gzip-friendly, easy to
    inspect. SQLite exports a self-contained DB file that can be directly used
    as $AI_HIST_DB on another machine.

    Examples:
        ai-hist export                          # JSONL to stdout
        ai-hist export history.jsonl            # JSONL to file
        ai-hist export history.jsonl.gz         # gzip-compressed JSONL
        ai-hist export backup.db --format sqlite
        ai-hist export --source claude --since 2025-01-01 recent.jsonl
    """
    if not DB_PATH.exists():
        print(f"No database found at {DB_PATH}. Run `ai-hist sync` first.", file=sys.stderr)
        sys.exit(1)

    fmt = getattr(args, "format", "jsonl") or "jsonl"
    output = getattr(args, "output", None)

    conn = sqlite3.connect(str(DB_PATH))
    init_db(conn)
    if output == "commit-links":
        if not getattr(args, "jsonl", False):
            print("commit-link export is JSONL-only; pass `ai-hist export commit-links --jsonl`", file=sys.stderr)
            sys.exit(1)
        sql = (
            "SELECT source, session_id, repo, branch, commit_sha, note_ref, match_method, confidence, "
            "files_json, numstat_json, evidence_json, created_at_ms "
            "FROM session_commit_links WHERE 1=1"
        )
        params = []
        if getattr(args, "source", None):
            sql += " AND source = ?"
            params.append(args.source)
        repo = getattr(args, "repo", None) or getattr(args, "project", None)
        if repo:
            sql += " AND repo LIKE ?"
            params.append(f"%{repo}%")
        if getattr(args, "since", None):
            sql += " AND created_at_ms >= ?"
            params.append(_parse_date_to_ms(args.since))
        sql += " ORDER BY created_at_ms ASC, id ASC"
        for row in conn.execute(sql, params):
            source, session_id, repo, branch, commit_sha, note_ref, match_method, confidence, files_json, numstat_json, evidence_json, created_at_ms = row
            print(json.dumps({
                "source": source,
                "session_id": session_id,
                "repo": repo,
                "branch": branch,
                "commit_sha": commit_sha,
                "note_ref": note_ref,
                "match_method": match_method,
                "confidence": confidence,
                "files_json": json.loads(files_json) if files_json else None,
                "numstat_json": json.loads(numstat_json) if numstat_json else None,
                "evidence_json": json.loads(evidence_json) if evidence_json else None,
                "created_at_ms": created_at_ms,
            }))
        conn.close()
        return
    rows = _query_export_rows(conn, args)
    conn.close()

    if not rows:
        print("No entries matched the export filters.", file=sys.stderr)
        sys.exit(1)

    if fmt == "sqlite":
        dest = output or "ai-hist-export.db"
        if Path(dest).resolve() == DB_PATH.resolve():
            print("Refusing to export SQLite over the active AI_HIST_DB.", file=sys.stderr)
            sys.exit(1)
        try:
            Path(dest).unlink()
        except FileNotFoundError:
            pass
        dst = sqlite3.connect(dest)
        init_db(dst)
        inserted = 0
        for row in rows:
            cur = dst.execute(
                "INSERT OR IGNORE INTO history "
                "(source, session_id, project, prompt, prompt_hash, timestamp_ms) "
                "VALUES (?, ?, ?, ?, ?, ?)",
                row,
            )
            if cur.rowcount > 0:
                inserted += 1
        dst.commit()
        dst.close()
        print(f"Exported {inserted:,} entries to {dest}")
        return

    # JSONL (default) — stdout or file
    def write_jsonl(f):
        for row in rows:
            f.write(json.dumps(dict(zip(_EXPORT_FIELDS, row))) + "\n")

    if output:
        with _open_file(output, "wt") as f:
            write_jsonl(f)
        print(f"Exported {len(rows):,} entries to {output}", file=sys.stderr)
    else:
        write_jsonl(sys.stdout)


def _load_rows_from_sqlite(path):
    """Load rows from an exported SQLite DB, tolerating missing prompt_hash."""
    try:
        src = sqlite3.connect(path)
        cols = {r[1] for r in src.execute("PRAGMA table_info(history)").fetchall()}
        if "prompt_hash" in cols:
            sql = "SELECT source, session_id, project, prompt, prompt_hash, timestamp_ms FROM history"
            fields = _EXPORT_FIELDS
        else:
            sql = "SELECT source, session_id, project, prompt, timestamp_ms FROM history"
            fields = ["source", "session_id", "project", "prompt", "timestamp_ms"]
        rows = [dict(zip(fields, r)) for r in src.execute(sql).fetchall()]
        src.close()
        return rows
    except sqlite3.Error as e:
        print(f"Error reading SQLite file: {e}", file=sys.stderr)
        sys.exit(1)


def _load_rows_from_jsonl(path):
    """Load rows from a JSONL (optionally gzip-compressed) export file."""
    rows = []
    try:
        with _open_file(path) as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    rows.append(json.loads(line))
                except json.JSONDecodeError:
                    pass
    except (OSError, EOFError) as e:
        print(f"Error reading {path}: {e}", file=sys.stderr)
        sys.exit(1)
    return rows


def cmd_import(args):
    """Import history from a JSONL or SQLite export file.

    Entries that already exist (same source + timestamp + prompt) are silently
    skipped, so it is safe to import the same file multiple times or merge
    overlapping exports from different machines.

    Examples:
        ai-hist import colleague.jsonl
        ai-hist import colleague.jsonl.gz
        ai-hist import colleague.db
        ai-hist import colleague.jsonl --dry-run
    """
    if getattr(args, "watch", False):
        if args.file:
            print("`ai-hist import --watch` does not accept an import file.", file=sys.stderr)
            sys.exit(1)
        cmd_watch(args)
        return

    path = args.file
    if not path:
        print("`ai-hist import` requires FILE unless --watch is set.", file=sys.stderr)
        sys.exit(1)
    dry_run = getattr(args, "dry_run", False)

    if path.endswith(".db") or path.endswith(".sqlite"):
        rows = _load_rows_from_sqlite(path)
    else:
        rows = _load_rows_from_jsonl(path)

    if not rows:
        print("No entries found in file.")
        return

    total = len(rows)

    if dry_run:
        print(f"[dry-run] {total:,} entries in {path} — none written.")
        print()
        for row in rows[:5]:
            source = row.get("source", "?")
            project = row.get("project") or ""
            prompt = row.get("prompt", "")[:80].replace("\n", " ")
            ts_ms = row.get("timestamp_ms", 0)
            dt = time.strftime("%Y-%m-%d %H:%M", time.localtime(ts_ms / 1000)) if ts_ms else "?"
            proj = f" [{project}]" if project else ""
            print(f"  {dt}  ({source}){proj}  {prompt}")
        if total > 5:
            print(f"  ... and {total - 5:,} more")
        return

    DB_PATH.parent.mkdir(parents=True, exist_ok=True)
    conn = sqlite3.connect(str(DB_PATH))
    init_db(conn)

    inserted = 0
    errors = 0
    for row in rows:
        prompt = row.get("prompt", "")
        if not prompt:
            continue
        try:
            cur = conn.execute(
                "INSERT OR IGNORE INTO history "
                "(source, session_id, project, prompt, prompt_hash, timestamp_ms) "
                "VALUES (?, ?, ?, ?, ?, ?)",
                (
                    row.get("source", ""),
                    row.get("session_id"),
                    row.get("project"),
                    prompt,
                    row.get("prompt_hash") or _prompt_hash(prompt),
                    row.get("timestamp_ms", 0),
                ),
            )
            if cur.rowcount > 0:
                inserted += 1
        except sqlite3.Error:
            errors += 1

    conn.commit()
    conn.close()

    skipped = total - inserted - errors
    parts = [f"+{inserted:,} new entries"]
    if skipped:
        parts.append(f"{skipped:,} already existed")
    if errors:
        parts.append(f"{errors} errors")
    print(f"Imported from {path}: {', '.join(parts)}")


