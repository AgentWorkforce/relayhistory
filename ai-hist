#!/usr/bin/env python3
"""
Rust-first ai-hist dispatcher.

The Rust CLI is the default for commands whose flag surface is covered by the
cutover tests. Python remains available as the legacy fallback for sync and for
Python-only flags while parity work continues.
"""

import os
import subprocess
import sys
from pathlib import Path


ROOT = Path(__file__).resolve().parent
PYTHON_CLI = ROOT / "ai-hist-python"
RUST_MANIFEST = ROOT / "Cargo.toml"

RUST_COMMANDS = {
    "search",
    "recent",
    "session",
    "resume",
    "sync-opencode",
}

PYTHON_COMMANDS = {
    "sync",
    "show",
    "context",
    "stats",
    "pack",
    "watch",
    "export",
    "import",
    "tag",
    "untag",
    "tags",
}

PYTHON_ONLY_FLAGS = {
    "session": {"--full"},
    "resume": {"--json"},
}


def main():
    mode = os.environ.get("AI_HIST_CLI", "auto").strip().lower()
    if mode not in {"auto", "rust", "python"}:
        print(
            "ai-hist: AI_HIST_CLI must be one of auto, rust, or python",
            file=sys.stderr,
        )
        return 2

    argv = sys.argv[1:]
    if mode == "python":
        return run_python(argv, warn=False)
    if mode == "rust":
        return run_rust(argv)

    route, reason = route_auto(argv)
    if route == "python":
        return run_python(argv, warn=True, reason=reason)
    return run_rust(argv)


def route_auto(argv):
    if not argv:
        return "rust", None
    first = argv[0]
    if first in {"-h", "--help", "-V", "--version", "help"}:
        return "rust", None
    if first in PYTHON_COMMANDS:
        return "python", f"`{first}` is still implemented by the legacy Python CLI"
    if first in PYTHON_ONLY_FLAGS:
        used = [arg for arg in argv[1:] if arg in PYTHON_ONLY_FLAGS[first]]
        if used:
            return (
                "python",
                f"`{first}` option(s) {', '.join(used)} are still implemented by the legacy Python CLI",
            )
    if first in RUST_COMMANDS:
        return "rust", None
    return "rust", None


def run_python(argv, warn=False, reason=None):
    if warn:
        detail = f": {reason}" if reason else ""
        print(
            f"ai-hist: using deprecated Python fallback{detail}",
            file=sys.stderr,
        )
    return subprocess.run([sys.executable, str(PYTHON_CLI), *argv]).returncode


def run_rust(argv):
    built = find_built_rust()
    if built:
        cmd = [str(built), *argv]
    else:
        cmd = [
            "cargo",
            "run",
            "-q",
            "-p",
            "ai-hist-cli",
            "--manifest-path",
            str(RUST_MANIFEST),
            "--",
            *argv,
        ]
    return subprocess.run(cmd).returncode


def find_built_rust():
    exe = "ai-hist.exe" if os.name == "nt" else "ai-hist"
    for path in (ROOT / "target" / "release" / exe, ROOT / "target" / "debug" / exe):
        if path.exists() and os.access(path, os.X_OK):
            return path
    return None


if __name__ == "__main__":
    raise SystemExit(main())
